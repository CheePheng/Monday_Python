# monday.com personal API token (monday > avatar > Developers > My Access Tokens)
MONDAY_API_TOKEN=
# Board used ONLY by monday_smoke_test (numeric id from the board URL)
TEST_BOARD_ID=

# HubSpot Private App access token (scopes: crm.objects.deals.read, crm.objects.owners.read)
HUBSPOT_ACCESS_TOKEN=

# Safety switch: True = NO writes to monday (payloads are printed instead).
# Smoke test AND router both honor this.
DRY_RUN=True

# Routing config + how many recent deals to pull
CONFIG_PATH=config.json
HUBSPOT_DEALS_LIMIT=10
